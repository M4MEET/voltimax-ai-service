# ============================================================
# VoltimaxChat AI Service — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit the .env file to git.
# ============================================================

# ── MongoDB ─────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/voltimax_chat

# ── Config Path ─────────────────────────────────────────────
CONFIG_PATH=config.yaml

# ── LangSmith (Tracing & Observability) ─────────────────────
# Get your key at: https://smith.langchain.com/settings
LANGCHAIN_API_KEY=lsv2_pt_your_key_here
LANGCHAIN_TRACING_V2=true
LANGSMITH_TRACING=true
LANGCHAIN_PROJECT=VoltimaxChat-Groot
LANGCHAIN_ENDPOINT=https://eu.api.smith.langchain.com
LANGSMITH_API_KEY=lsv2_pt_your_key_here
LANGSMITH_ENDPOINT=https://eu.api.smith.langchain.com
LANGSMITH_PROJECT=VoltimaxChat-Groot

# ── LLM API Keys (used by LangGraph Studio & direct calls) ──
ANTHROPIC_API_KEY=sk-ant-api03-your_key_here
OPENAI_API_KEY=sk-proj-your_key_here

# ── Mail server hostname ────────────────────────────────────
# Used by docker-compose extra_hosts to route the on-host mail server via
# the host gateway (containers can't reach the host's own public IP).
# Must match escalation.smtp.host in config.yaml.
SMTP_HOST=mail.example.com
